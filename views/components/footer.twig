<footer class="bg-navy-dark text-white pt-20 pb-10 border-t border-white/5">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">

            {# عن المتجر #}
            <div>
                <a href="{{ link('/') }}" class="text-3xl font-black tracking-tighter text-white mb-6 inline-block">
                    {% if store.logo %}
                        <img src="{{ store.logo }}" alt="{{ store.name }}" class="h-10 max-w-[160px] object-contain brightness-0 invert">
                    {% else %}
                        <span class="text-gold">{{ store.name|slice(0,3)|upper }}</span>{{ store.name|slice(3)|upper }}<span class="text-gold">.</span>
                    {% endif %}
                </a>
                <p class="text-gray-400 leading-relaxed mb-8 text-sm">
                    {{ store.description|default(trans('common.elements.newsletter_title')) }}
                </p>
                {# روابط التواصل الاجتماعي #}
                {% if store.social is defined and store.social|length %}
                <div class="flex gap-3">
                    {% for social in store.social %}
                        <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" aria-label="{{ social.name }}"
                            class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-gold hover:border-gold transition-all duration-300">
                            <i data-lucide="{{ social.name }}" class="w-4 h-4"></i>
                        </a>
                    {% endfor %}
                </div>
                {% endif %}
            </div>

            {# روابط سريعة #}
            <div>
                <h4 class="text-base font-bold mb-6 border-b border-white/10 pb-4">{{ trans('common.elements.quick_links') }}</h4>
                <ul class="space-y-3 text-gray-400 text-sm">
                    <li><a href="{{ link('/') }}" class="hover:text-gold transition-colors flex items-center gap-2"><i data-lucide="chevron-left" class="w-3 h-3 text-gold/50"></i>{{ trans('common.elements.home') }}</a></li>
                    <li><a href="{{ link('about-us') }}" class="hover:text-gold transition-colors flex items-center gap-2"><i data-lucide="chevron-left" class="w-3 h-3 text-gold/50"></i>{{ trans('common.elements.about_us') }}</a></li>
                    <li><a href="{{ link('privacy-policy') }}" class="hover:text-gold transition-colors flex items-center gap-2"><i data-lucide="chevron-left" class="w-3 h-3 text-gold/50"></i>{{ trans('common.elements.privacy_policy') }}</a></li>
                    <li><a href="{{ link('terms-conditions') }}" class="hover:text-gold transition-colors flex items-center gap-2"><i data-lucide="chevron-left" class="w-3 h-3 text-gold/50"></i>{{ trans('common.elements.terms_conditions') }}</a></li>
                    <li><a href="{{ link('faq') }}" class="hover:text-gold transition-colors flex items-center gap-2"><i data-lucide="chevron-left" class="w-3 h-3 text-gold/50"></i>{{ trans('common.elements.faq') }}</a></li>
                    <li><a href="{{ link('contact') }}" class="hover:text-gold transition-colors flex items-center gap-2"><i data-lucide="chevron-left" class="w-3 h-3 text-gold/50"></i>{{ trans('common.elements.contact_us') }}</a></li>
                </ul>
            </div>

            {# معلومات التواصل #}
            <div>
                <h4 class="text-base font-bold mb-6 border-b border-white/10 pb-4">{{ trans('common.elements.contact_us') }}</h4>
                <ul class="space-y-5 text-gray-400 text-sm">
                    {% if store.contacts is defined %}
                        {% if store.contacts.location %}
                            <li class="flex items-start gap-4">
                                <i data-lucide="map-pin" class="w-5 h-5 text-gold shrink-0 mt-0.5"></i>
                                <span>{{ store.contacts.location }}</span>
                            </li>
                        {% endif %}
                        {% if store.contacts.phone %}
                            <li class="flex items-center gap-4">
                                <i data-lucide="phone" class="w-5 h-5 text-gold shrink-0"></i>
                                <a href="tel:{{ store.contacts.phone }}" dir="ltr" class="hover:text-gold transition-colors">{{ store.contacts.phone }}</a>
                            </li>
                        {% endif %}
                        {% if store.contacts.email %}
                            <li class="flex items-center gap-4">
                                <i data-lucide="mail" class="w-5 h-5 text-gold shrink-0"></i>
                                <a href="mailto:{{ store.contacts.email }}" class="hover:text-gold transition-colors">{{ store.contacts.email }}</a>
                            </li>
                        {% endif %}
                    {% endif %}
                </ul>
            </div>

            {# النشرة البريدية #}
            <div>
                <h4 class="text-base font-bold mb-6 border-b border-white/10 pb-4">{{ trans('common.elements.newsletter_title') }}</h4>
                <p class="text-gray-400 mb-5 text-sm leading-relaxed">اشترك للحصول على آخر العروض والخصومات الحصرية.</p>
                <form salla-subscribe class="space-y-3">
                    <div class="relative">
                        <input type="email" name="email"
                            placeholder="{{ trans('common.elements.newsletter_placeholder') }}"
                            required
                            aria-label="{{ trans('common.elements.newsletter_placeholder') }}"
                            class="w-full bg-white/5 border border-white/10 rounded-xl py-4 px-5 focus:outline-none focus:border-gold transition-colors text-sm">
                    </div>
                    <button type="submit"
                        class="w-full bg-gold text-white py-4 rounded-xl font-bold text-sm hover:bg-white hover:text-navy-dark transition-all duration-300">
                        {{ trans('common.elements.newsletter_btn') }}
                    </button>
                </form>
            </div>
        </div>

        {# الذيل السفلي #}
        <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-6">
            <p class="text-gray-500 text-sm">
                &copy; {{ "now"|date("Y") }} {{ store.name }}. جميع الحقوق محفوظة.
            </p>
            {# شعارات الدفع #}
            <div class="flex items-center gap-4 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500">
                <img src="https://salla.sa/assets/images/payment/mada.png" alt="Mada" class="h-5" loading="lazy">
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2a/Mastercard-logo.svg/1280px-Mastercard-logo.svg.png" alt="Mastercard" class="h-6" loading="lazy">
                <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/5/5e/Visa_Inc._logo.svg/2560px-Visa_Inc._logo.svg.png" alt="Visa" class="h-4" loading="lazy">
            </div>
        </div>
    </div>
</footer>
