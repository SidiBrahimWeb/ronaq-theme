<header id="main-header"
    class="bg-white/90 backdrop-blur-xl sticky top-0 z-50 transition-all duration-500 border-b border-neutral-100">
    <div class="container mx-auto px-4 lg:px-8">
        <div class="flex items-center justify-between h-20 md:h-24 transition-all duration-500" id="header-inner">

            {# زر قائمة الجوال #}
            <button id="mobile-menu-btn" aria-label="القائمة"
                class="lg:hidden p-3 text-navy-dark hover:bg-neutral-100 rounded-2xl transition-all">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>

            {# الشعار #}
            <div class="flex items-center flex-1">
                <a href="{{ link('/') }}" class="flex flex-col items-start group" aria-label="{{ store.name }}">
                    {% if store.logo %}
                        <img src="{{ store.logo }}" alt="{{ store.name }}" class="h-10 max-w-[160px] object-contain">
                    {% else %}
                        <span class="text-2xl md:text-3xl font-black tracking-tighter text-navy-dark">
                            <span class="text-gold">{{ store.name|slice(0,3)|upper }}</span>{{ store.name|slice(3)|upper }}<span class="text-gold">.</span>
                        </span>
                        <span class="text-[9px] uppercase tracking-[0.3em] text-neutral-400 font-bold mt-1 group-hover:text-gold transition-colors">PREMIUM EXPERIENCE</span>
                    {% endif %}
                </a>
            </div>

            {# البحث - Desktop #}
            <div class="hidden lg:flex items-center justify-center flex-1 max-w-md mx-auto group">
                <form action="{{ link('search') }}" method="GET" role="search" class="relative w-full">
                    <input type="text" name="q" placeholder="{{ trans('common.elements.search_placeholder') }}"
                        aria-label="{{ trans('common.elements.search') }}"
                        class="w-full bg-neutral-100/50 border border-transparent rounded-2xl py-3 px-12 focus:outline-none focus:bg-white focus:border-gold focus:ring-4 focus:ring-gold/5 transition-all text-sm text-center">
                    <i data-lucide="search"
                        class="w-5 h-5 absolute right-4 top-1/2 -translate-y-1/2 text-neutral-400 group-focus-within:text-gold transition-colors pointer-events-none"></i>
                </form>
            </div>

            {# أيقونات: حساب / مفضلة / سلة #}
            <div class="flex items-center justify-end flex-1 gap-2 md:gap-3">
                {% if user.is_authenticated %}
                    <a href="{{ link('profile') }}" aria-label="{{ trans('common.elements.my_account') }}"
                        class="hidden md:flex p-3 text-navy-dark hover:text-gold hover:bg-gold/5 rounded-full transition-all">
                        <i data-lucide="user" class="w-6 h-6"></i>
                    </a>
                {% else %}
                    <a href="{{ link('login') }}" aria-label="{{ trans('common.elements.login') }}"
                        class="hidden md:flex p-3 text-navy-dark hover:text-gold hover:bg-gold/5 rounded-full transition-all">
                        <i data-lucide="user" class="w-6 h-6"></i>
                    </a>
                {% endif %}

                {# زر البحث - Mobile #}
                <button id="mobile-search-btn" aria-label="{{ trans('common.elements.search') }}"
                    class="lg:hidden p-3 text-navy-dark hover:text-gold hover:bg-gold/5 rounded-full transition-all">
                    <i data-lucide="search" class="w-6 h-6"></i>
                </button>

                {# المفضلة #}
                <a href="{{ link('wishlist') }}" aria-label="{{ trans('common.elements.wishlist') }}"
                    class="relative p-3 text-navy-dark hover:text-gold hover:bg-gold/5 rounded-full transition-all">
                    <i data-lucide="heart" class="w-6 h-6"></i>
                    {% if wishlist is defined and wishlist.count > 0 %}
                        <span class="absolute top-2 right-2 bg-red-500 text-white text-[9px] font-black w-4 h-4 rounded-full flex items-center justify-center border-2 border-white">{{ wishlist.count }}</span>
                    {% endif %}
                </a>

                {# السلة #}
                <a href="{{ link('cart') }}" aria-label="{{ trans('common.elements.cart') }}"
                    class="relative p-3 text-navy-dark hover:text-gold hover:bg-gold/5 rounded-full transition-all">
                    <i data-lucide="shopping-bag" class="w-6 h-6"></i>
                    {% if cart is defined and cart.count > 0 %}
                        <span class="absolute top-2 right-2 bg-navy-dark text-white text-[9px] font-black w-4 h-4 rounded-full flex items-center justify-center border-2 border-white">{{ cart.count }}</span>
                    {% endif %}
                </a>
            </div>
        </div>
    </div>

    {# قائمة التنقل الرئيسية - Desktop #}
    <nav aria-label="التنقل الرئيسي" class="hidden lg:block border-t border-gray-50 bg-white">
        <div class="container mx-auto px-4">
            <ul class="flex items-center justify-center gap-8 py-3" role="list">
                <li>
                    <a href="{{ link('/') }}"
                        class="text-sm font-bold hover:text-gold transition-colors flex items-center gap-1 py-2">
                        {{ trans('common.elements.home') }}
                    </a>
                </li>

                {% for category in categories %}
                <li class="group relative">
                    <a href="{{ category.url }}"
                        class="text-sm font-bold hover:text-gold transition-colors flex items-center gap-1 py-2">
                        {{ category.name }}
                        {% if category.sub_categories is defined and category.sub_categories|length %}
                            <i data-lucide="chevron-down" class="w-3 h-3 transition-transform group-hover:rotate-180"></i>
                        {% endif %}
                    </a>

                    {% if category.sub_categories is defined and category.sub_categories|length %}
                    <div class="absolute top-full right-0 w-[420px] bg-white shadow-2xl rounded-b-2xl border-t-2 border-gold opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 p-6 grid grid-cols-2 gap-6">
                        <div>
                            <h4 class="font-bold text-navy-dark mb-4 border-b border-gray-100 pb-2 text-sm">التصنيفات الفرعية</h4>
                            <ul class="space-y-2">
                                {% for sub in category.sub_categories %}
                                    <li>
                                        <a href="{{ sub.url }}" class="text-sm text-gray-500 hover:text-gold transition-colors flex items-center gap-2">
                                            <i data-lucide="chevron-left" class="w-3 h-3 text-gold shrink-0"></i>
                                            {{ sub.name }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                        {% if category.image %}
                        <div class="bg-gray-50 rounded-xl p-4 flex flex-col justify-center items-center text-center">
                            <img src="{{ category.image }}" alt="{{ category.name }}" class="rounded-lg mb-3 shadow-md w-full aspect-video object-cover">
                            <p class="text-xs font-bold text-gold mb-1">اكتشف الآن</p>
                            <p class="text-sm font-bold text-navy-dark">{{ category.name }}</p>
                        </div>
                        {% endif %}
                    </div>
                    {% endif %}
                </li>
                {% endfor %}

                <li>
                    <a href="{{ link('offers') }}"
                        class="text-sm font-bold text-red-600 hover:text-red-700 transition-colors flex items-center gap-1 py-2 relative">
                        {{ trans('common.elements.offers') }}
                        <span class="absolute -top-1 -left-5 bg-red-600 text-white text-[8px] px-1.5 py-0.5 rounded-full">جديد</span>
                    </a>
                </li>
                <li>
                    <a href="{{ link('about-us') }}"
                        class="text-sm font-bold hover:text-gold transition-colors flex items-center gap-1 py-2">
                        {{ trans('common.elements.about_us') }}
                    </a>
                </li>
                <li>
                    <a href="{{ link('contact') }}"
                        class="text-sm font-bold hover:text-gold transition-colors flex items-center gap-1 py-2">
                        {{ trans('common.elements.contact_us') }}
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    {# شريط البحث المتحرك - Mobile #}
    <div id="mobile-search-bar" class="hidden border-t border-gray-100 px-4 py-3 bg-white">
        <form action="{{ link('search') }}" method="GET" role="search" class="relative">
            <input type="text" name="q" placeholder="{{ trans('common.elements.search_placeholder') }}"
                aria-label="{{ trans('common.elements.search') }}"
                class="w-full bg-gray-50 border border-gray-200 rounded-xl py-3 px-4 pr-11 focus:outline-none focus:border-gold text-sm transition-colors">
            <i data-lucide="search" class="w-4 h-4 absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none"></i>
        </form>
    </div>
</header>
