<section id="about-us" class="py-24 bg-white overflow-hidden" aria-label="من نحن">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

            {# الصورة #}
            <div class="relative">
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-gold/10 rounded-full blur-3xl"></div>
                <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-navy-dark/5 rounded-full blur-3xl"></div>
                <div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl group">
                    <img src="https://images.unsplash.com/photo-1556740758-90de374c12ad?auto=format&fit=crop&q=80&w=800"
                        alt="قصتنا"
                        class="w-full aspect-[4/3] object-cover transition-transform duration-1000 group-hover:scale-105"
                        loading="lazy">
                    <div class="absolute inset-0 bg-gradient-to-t from-navy-dark/30 to-transparent"></div>
                </div>
                <div class="absolute -bottom-6 -right-6 bg-white p-6 rounded-2xl shadow-2xl hidden md:block border border-gray-100">
                    <p class="text-4xl font-black text-gold mb-1">+10</p>
                    <p class="text-xs font-bold text-navy-dark uppercase tracking-widest">سنوات من الخبرة</p>
                </div>
            </div>

            {# النص #}
            <div class="space-y-7">
                <div class="inline-flex items-center gap-3 bg-gold/10 px-4 py-2 rounded-full">
                    <span class="w-2 h-2 rounded-full bg-gold"></span>
                    <span class="text-xs font-black text-gold uppercase tracking-widest">قصة الفخامة</span>
                </div>
                <h2 class="text-4xl lg:text-5xl font-black text-navy-dark leading-tight">
                    نسعى لصياغة <span class="text-gold">مفهوم جديد</span> للرفاهية
                </h2>
                <p class="text-neutral-500 text-base lg:text-lg leading-relaxed">
                    {{ store.description|default('في متجرنا، لا نؤمن بأن الفخامة مجرد سعر، بل هي قصة تُروى من خلال الجودة والاهتمام بأدق التفاصيل. بدأنا شغفنا لنقدم لعملائنا تجربة تسوق تحاكي أرقى بيوت الموضة العالمية.') }}
                </p>
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <li class="flex items-center gap-4">
                        <div class="w-11 h-11 rounded-2xl bg-gold/10 flex items-center justify-center shrink-0">
                            <i data-lucide="award" class="w-5 h-5 text-gold"></i>
                        </div>
                        <span class="font-bold text-navy-dark">جودة عالمية معتمدة</span>
                    </li>
                    <li class="flex items-center gap-4">
                        <div class="w-11 h-11 rounded-2xl bg-gold/10 flex items-center justify-center shrink-0">
                            <i data-lucide="shield-check" class="w-5 h-5 text-gold"></i>
                        </div>
                        <span class="font-bold text-navy-dark">منتجات أصلية 100%</span>
                    </li>
                    <li class="flex items-center gap-4">
                        <div class="w-11 h-11 rounded-2xl bg-gold/10 flex items-center justify-center shrink-0">
                            <i data-lucide="truck" class="w-5 h-5 text-gold"></i>
                        </div>
                        <span class="font-bold text-navy-dark">توصيل سريع وآمن</span>
                    </li>
                    <li class="flex items-center gap-4">
                        <div class="w-11 h-11 rounded-2xl bg-gold/10 flex items-center justify-center shrink-0">
                            <i data-lucide="headphones" class="w-5 h-5 text-gold"></i>
                        </div>
                        <span class="font-bold text-navy-dark">دعم عملاء على مدار الساعة</span>
                    </li>
                </ul>
                <a href="{{ link('about-us') }}"
                    class="inline-flex items-center gap-3 font-black text-navy-dark hover:text-gold transition-colors group">
                    تعرف على المزيد عن رؤيتنا
                    <i data-lucide="arrow-left" class="w-5 h-5 group-hover:-translate-x-2 transition-transform text-gold"></i>
                </a>
            </div>
        </div>
    </div>
</section>
