{% if products is defined and products|length %}
<section class="py-20 bg-soft-white overflow-hidden" aria-label="المنتجات المميزة">
    <div class="container mx-auto px-4">
        <div class="flex items-end justify-between mb-12">
            <div class="relative">
                <span class="text-gold font-bold text-sm mb-2 block tracking-widest uppercase">
                    {{ theme.settings.featured_products_subtitle|default('مجموعتنا الجديدة') }}
                </span>
                <h2 class="text-4xl lg:text-5xl font-black text-navy-dark mb-3">
                    {{ theme.settings.featured_products_title|default('وصل حديثاً') }}
                </h2>
                <div class="w-14 h-1.5 bg-gold rounded-full"></div>
            </div>
            <div class="flex gap-3">
                <button aria-label="السابق"
                    class="featured-prev w-12 h-12 rounded-full border border-gray-200 bg-white hover:bg-gold hover:text-white hover:border-gold transition-all duration-500 shadow-sm flex items-center justify-center group">
                    <i data-lucide="chevron-right" class="w-6 h-6 transition-transform group-hover:scale-110"></i>
                </button>
                <button aria-label="التالي"
                    class="featured-next w-12 h-12 rounded-full border border-gray-200 bg-white hover:bg-gold hover:text-white hover:border-gold transition-all duration-500 shadow-sm flex items-center justify-center group">
                    <i data-lucide="chevron-left" class="w-6 h-6 transition-transform group-hover:scale-110"></i>
                </button>
            </div>
        </div>

        <div class="swiper featured-swiper pb-12">
            <div class="swiper-wrapper">
                {% for product in products %}
                <div class="swiper-slide h-auto">
                    <div class="group relative bg-white rounded-[2rem] overflow-hidden border border-neutral-200/60 h-full flex flex-col transition-all duration-700 hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.12)] hover:border-gold/30 hover:-translate-y-3">
                        {# صورة المنتج #}
                        <div class="relative aspect-[4/5] overflow-hidden bg-soft-white">
                            <a href="{{ product.url }}" class="block w-full h-full" aria-label="{{ product.name }}">
                                <img src="{{ product.image.url }}" alt="{{ product.name }}"
                                    class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110"
                                    loading="lazy">
                            </a>
                            {# شارات #}
                            <div class="absolute top-5 right-5 flex flex-col gap-2">
                                {% if product.on_sale %}
                                    <span class="bg-red-600/90 backdrop-blur-md text-white text-[10px] font-black px-3 py-1.5 rounded-full">
                                        خصم {{ product.discount_percentage }}%
                                    </span>
                                {% endif %}
                                {% if product.is_new %}
                                    <span class="bg-navy-dark/90 backdrop-blur-md text-white text-[10px] font-black px-3 py-1.5 rounded-full border border-gold/30">
                                        {{ trans('common.elements.new') }}
                                    </span>
                                {% endif %}
                            </div>
                            {# زر المفضلة #}
                            <button salla-wishlist-add="{{ product.id }}"
                                aria-label="{{ trans('common.elements.add_to_wishlist') }}"
                                class="absolute top-5 left-5 w-10 h-10 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-navy-dark hover:bg-red-500 hover:text-white transition-all duration-300 shadow-lg opacity-0 group-hover:opacity-100 -translate-x-4 group-hover:translate-x-0">
                                <i data-lucide="heart" class="w-5 h-5"></i>
                            </button>
                        </div>

                        {# معلومات المنتج #}
                        <div class="p-5 flex flex-col flex-grow">
                            <div class="mb-4">
                                <p class="text-[10px] uppercase tracking-widest text-gold font-bold mb-1">
                                    {{ product.category.name|default('') }}
                                </p>
                                <h3 class="font-bold text-navy-dark text-base group-hover:text-gold transition-colors line-clamp-1">
                                    <a href="{{ product.url }}">{{ product.name }}</a>
                                </h3>
                                {% if product.rating is defined and product.rating %}
                                    <div class="flex items-center gap-1 mt-1">
                                        <i data-lucide="star" class="w-3 h-3 text-gold fill-current"></i>
                                        <span class="text-xs text-gray-400 font-bold">{{ product.rating }}</span>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-50">
                                <div class="flex flex-col">
                                    <span class="text-navy-dark font-black text-lg">{{ product.price|money }}</span>
                                    {% if product.on_sale %}
                                        <span class="text-gray-300 line-through text-xs">{{ product.regular_price|money }}</span>
                                    {% endif %}
                                </div>
                                <button salla-cart-add="{{ product.id }}"
                                    aria-label="{{ trans('common.elements.add_to_cart') }}"
                                    class="w-11 h-11 bg-navy-dark text-white rounded-2xl flex items-center justify-center hover:bg-gold transition-all duration-500 shadow-lg shadow-navy-dark/10 group/btn">
                                    <i data-lucide="shopping-bag" class="w-5 h-5 transition-transform group-hover/btn:scale-110"></i>
                                </button>
                            </div>
                        </div>

                        {# زر إضافة للسلة كامل العرض #}
                        <div class="px-5 pb-5 mt-auto">
                            <button salla-cart-add="{{ product.id }}"
                                class="w-full py-3.5 bg-gray-50 hover:bg-gold text-navy-dark hover:text-white rounded-2xl font-bold text-sm transition-all duration-500 flex items-center justify-center gap-2 group/add">
                                <span>{{ trans('common.elements.add_to_cart') }}</span>
                                <i data-lucide="plus" class="w-4 h-4 transition-transform group-hover/add:rotate-90"></i>
                            </button>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            <div class="swiper-pagination featured-pagination !-bottom-2"></div>
        </div>

        {# رابط عرض الكل #}
        <div class="text-center mt-6">
            <a href="{{ link('/') }}" class="inline-flex items-center gap-2 text-navy-dark font-bold hover:text-gold transition-colors">
                {{ trans('common.elements.view_all') }}
                <i data-lucide="arrow-left" class="w-4 h-4"></i>
            </a>
        </div>
    </div>
</section>
{% endif %}
