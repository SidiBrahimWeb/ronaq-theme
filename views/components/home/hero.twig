<section class="relative h-[65vh] lg:h-[88vh] overflow-hidden" aria-label="البانر الرئيسي">
    {# صورة الخلفية #}
    <div class="absolute inset-0">
        <img src="{{ theme.settings.hero_image|default('https://images.unsplash.com/photo-1594035910387-fea47794261f?auto=format&fit=crop&q=80&w=2000') }}"
            alt="{{ theme.settings.hero_title|default('بانر رئيسي') }}"
            class="w-full h-full object-cover"
            loading="eager">
        <div class="absolute inset-0 bg-gradient-to-l from-navy-dark/90 via-navy-dark/50 to-navy-dark/20"></div>
    </div>

    {# المحتوى #}
    <div class="container mx-auto px-4 h-full relative z-10 flex items-center justify-center text-center">
        <div class="max-w-2xl text-white">
            <span class="inline-block px-5 py-1.5 bg-gold text-white text-xs font-black rounded-full mb-6 tracking-widest uppercase">
                {{ theme.settings.hero_subtitle|default('المجموعة الحصرية') }}
            </span>
            <h1 class="text-4xl lg:text-6xl font-black mb-6 leading-tight">
                {{ theme.settings.hero_title|default('فخامة التفاصيل تعكس شخصيتك')|raw }}
            </h1>
            <p class="text-gray-300 text-base lg:text-lg mb-10 max-w-lg mx-auto leading-relaxed">
                {{ theme.settings.hero_description|default('اكتشف تشكيلة واسعة من أرقى العطور والمجوهرات التي صممت خصيصاً لأصحاب الذوق الرفيع.') }}
            </p>
            <div class="flex flex-wrap justify-center gap-4">
                <a href="{{ theme.settings.hero_button_link|default(link('/')) }}"
                    class="bg-gold hover:bg-white hover:text-navy-dark text-white px-8 py-4 rounded-full font-bold transition-all duration-500 shadow-xl shadow-gold/30 flex items-center gap-3">
                    {{ theme.settings.hero_button_text|default('تسوق الآن') }}
                    <i data-lucide="arrow-left" class="w-5 h-5"></i>
                </a>
                <a href="{{ theme.settings.hero_secondary_button_link|default('#') }}"
                    class="bg-white/10 backdrop-blur-md border border-white/20 hover:bg-white/20 text-white px-8 py-4 rounded-full font-bold transition-all duration-500">
                    {{ theme.settings.hero_secondary_button_text|default('اكتشف المزيد') }}
                </a>
            </div>
        </div>
    </div>

    {# مؤشر التمرير #}
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/50 animate-bounce hidden md:block">
        <i data-lucide="chevrons-down" class="w-6 h-6"></i>
    </div>
</section>
