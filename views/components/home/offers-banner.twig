<section class="py-10 bg-white" aria-label="بانرات العروض">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            {# بانر 1 #}
            <div class="relative h-72 lg:h-80 rounded-3xl overflow-hidden group cursor-pointer">
                <img src="{{ theme.settings.promo_banner_1_image|default('https://images.unsplash.com/photo-1512132411229-c30391241dd8?auto=format&fit=crop&q=80&w=1000') }}"
                    alt="{{ theme.settings.promo_banner_1_title|default('عرض خاص') }}"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    loading="lazy">
                <div class="absolute inset-0 bg-gradient-to-l from-navy-dark/80 via-navy-dark/50 to-transparent p-8 lg:p-10 flex flex-col justify-end text-white">
                    <p class="text-gold text-xs font-black uppercase tracking-widest mb-2">عرض محدود</p>
                    <h3 class="text-2xl lg:text-3xl font-black mb-3 leading-tight">
                        {{ theme.settings.promo_banner_1_title|default('قسم الساعات الفاخرة')|raw }}
                    </h3>
                    <p class="mb-5 opacity-80 text-sm">{{ theme.settings.promo_banner_1_subtitle|default('خصومات تصل إلى 40%') }}</p>
                    <a href="{{ theme.settings.promo_banner_1_link|default('#') }}"
                        class="inline-flex items-center gap-2 w-fit bg-white text-navy-dark px-6 py-3 rounded-full font-bold text-sm hover:bg-gold hover:text-white transition-all duration-300 shadow-lg">
                        {{ theme.settings.promo_banner_1_btn_text|default('تسوق الآن') }}
                        <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>

            {# بانر 2 #}
            <div class="relative h-72 lg:h-80 rounded-3xl overflow-hidden group cursor-pointer">
                <img src="{{ theme.settings.promo_banner_2_image|default('https://images.unsplash.com/photo-1559056199-641a0ac8b55e?auto=format&fit=crop&q=80&w=1000') }}"
                    alt="{{ theme.settings.promo_banner_2_title|default('عرض خاص') }}"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                    loading="lazy">
                <div class="absolute inset-0 bg-gradient-to-l from-gold/80 via-gold/50 to-transparent p-8 lg:p-10 flex flex-col justify-end text-white">
                    <p class="text-white text-xs font-black uppercase tracking-widest mb-2 opacity-80">مجموعة حصرية</p>
                    <h3 class="text-2xl lg:text-3xl font-black mb-3 leading-tight">
                        {{ theme.settings.promo_banner_2_title|default('أطقم المجوهرات النادرة')|raw }}
                    </h3>
                    <p class="mb-5 opacity-80 text-sm">{{ theme.settings.promo_banner_2_subtitle|default('تصاميم فريدة تعكس أناقتك') }}</p>
                    <a href="{{ theme.settings.promo_banner_2_link|default('#') }}"
                        class="inline-flex items-center gap-2 w-fit bg-navy-dark text-white px-6 py-3 rounded-full font-bold text-sm hover:bg-white hover:text-navy-dark transition-all duration-300 shadow-lg">
                        {{ theme.settings.promo_banner_2_btn_text|default('اكتشف المجموعة') }}
                        <i data-lucide="arrow-left" class="w-4 h-4"></i>
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>
