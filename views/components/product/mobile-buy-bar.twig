        </button>
        <button salla-cart-add="{{ product.id }}"
            class="flex-[2] bg-navy-dark text-white py-3.5 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-gold transition-all duration-300 text-sm">
            <i data-lucide="shopping-bag" class="w-5 h-5"></i>
            {{ trans('common.elements.add_to_cart') }}
        </button>
    </div>
