<div class="lg:hidden fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-md border-t border-gray-100 p-4 z-50 shadow-[0_-10px_40px_rgba(0,0,0,0.05)]" id="mobile-buy-bar" role="complementary" aria-label="شراء المنتج">
    <div class="flex items-center gap-3">
        <div class="flex-1">
            <div class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">{{ trans('common.elements.total_price') }}</div>
            <div class="text-xl font-black text-navy-dark">{{ product.price|money }}</div>
        </div>
        <button salla-wishlist-add="{{ product.id }}"
            aria-label="{{ trans('common.elements.add_to_wishlist') }}"
            class="w-12 h-12 bg-gray-50 border border-gray-200 text-navy-dark rounded-xl flex items-center justify-center hover:text-red-500 hover:bg-red-50 hover:border-red-100 transition-all shrink-0">
