<div class="mt-20 lg:mt-28">
    {# تبويبات التنقل #}
    <div class="flex items-center border-b border-gray-100 gap-2 md:gap-8 mb-10 overflow-x-auto" role="tablist">
        <button data-tab="desc"
            role="tab" aria-selected="true" aria-controls="desc"
            class="tab-btn shrink-0 pb-5 px-2 border-b-2 border-gold text-gold font-black text-base transition-all">
            {{ trans('common.elements.description') }}
        </button>
        {% if product.features is defined and product.features|length %}
            <button data-tab="specs"
                role="tab" aria-selected="false" aria-controls="specs"
                class="tab-btn shrink-0 pb-5 px-2 border-b-2 border-transparent text-gray-400 font-black text-base hover:text-navy-dark transition-all">
                {{ trans('common.elements.features') }}
            </button>
        {% endif %}
        <button data-tab="shipping"
            role="tab" aria-selected="false" aria-controls="shipping"
            class="tab-btn shrink-0 pb-5 px-2 border-b-2 border-transparent text-gray-400 font-black text-base hover:text-navy-dark transition-all">
            {{ trans('common.elements.shipping_and_warranty') }}
        </button>
    </div>

    <div class="max-w-4xl mx-auto">
        {# تبويب الوصف #}
        <div id="desc" class="tab-pane transition-all duration-300" role="tabpanel">
            <div class="prose prose-lg max-w-none text-neutral-500 leading-loose">
                {{ product.description|raw }}
            </div>
        </div>

        {# تبويب المواصفات #}
        {% if product.features is defined and product.features|length %}
        <div id="specs" class="tab-pane hidden transition-all duration-300" role="tabpanel">
            <div class="bg-soft-white rounded-2xl overflow-hidden border border-neutral-100">
                <table class="w-full text-right">
                    <tbody>
                        {% for feature in product.features %}
                            <tr class="border-b border-white last:border-0">
                                <td class="p-5 font-bold text-navy-dark bg-gray-50/80 w-1/3 text-sm">{{ feature.label }}</td>
                                <td class="p-5 text-gray-500 text-sm">{{ feature.value }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}

        {# تبويب الشحن والضمان #}
        <div id="shipping" class="tab-pane hidden transition-all duration-300" role="tabpanel">
            <div class="space-y-5">
                <div class="flex gap-5 p-6 bg-soft-white rounded-2xl border border-neutral-100">
                    <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shrink-0 shadow-sm">
                        <i data-lucide="truck" class="w-6 h-6 text-gold"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-navy-dark mb-2">معلومات الشحن</h4>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            التوصيل داخل الرياض خلال 24 ساعة. باقي مدن المملكة خلال 2-4 أيام عمل. الشحن الدولي متاح لمعظم دول العالم خلال 5-10 أيام عمل.
                        </p>
                    </div>
                </div>
                <div class="flex gap-5 p-6 bg-soft-white rounded-2xl border border-neutral-100">
                    <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shrink-0 shadow-sm">
                        <i data-lucide="rotate-ccw" class="w-6 h-6 text-gold"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-navy-dark mb-2">سياسة الاسترجاع</h4>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            نضمن رضاك الكامل. يمكنك إرجاع المنتج خلال 7 أيام من تاريخ الاستلام، شريطة أن يكون بحالته الأصلية مع جميع ملحقاته وتغليفه الأصلي.
                        </p>
                    </div>
                </div>
                <div class="flex gap-5 p-6 bg-soft-white rounded-2xl border border-neutral-100">
                    <div class="w-12 h-12 bg-white rounded-2xl flex items-center justify-center shrink-0 shadow-sm">
                        <i data-lucide="shield-check" class="w-6 h-6 text-gold"></i>
                    </div>
                    <div>
                        <h4 class="font-bold text-navy-dark mb-2">الضمان والأصالة</h4>
                        <p class="text-sm text-gray-500 leading-relaxed">
                            جميع منتجاتنا أصلية 100% مع شهادات ضمان رسمية. نقدم ضمان الأصالة لجميع الساعات والمجوهرات، مع إمكانية التحقق المباشر من المصنّع.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
