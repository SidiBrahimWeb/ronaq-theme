{% if product.related_products is defined and product.related_products|length %}
<section class="mt-24 lg:mt-32" aria-label="منتجات ذات صلة">
    <div class="flex items-end justify-between mb-10">
        <div>
            <span class="text-gold font-bold text-xs tracking-widest uppercase block mb-2">قد يعجبك أيضاً</span>
            <h2 class="text-3xl font-black text-navy-dark mb-2">منتجات مشابهة</h2>
            <div class="w-12 h-1.5 bg-gold rounded-full"></div>
        </div>
        <div class="flex gap-3">
            <button class="related-prev w-12 h-12 rounded-full border border-gray-200 bg-white hover:bg-gold hover:text-white hover:border-gold transition-all shadow-sm flex items-center justify-center"
                aria-label="السابق">
                <i data-lucide="chevron-right" class="w-5 h-5"></i>
            </button>
            <button class="related-next w-12 h-12 rounded-full border border-gray-200 bg-white hover:bg-gold hover:text-white hover:border-gold transition-all shadow-sm flex items-center justify-center"
                aria-label="التالي">
                <i data-lucide="chevron-left" class="w-5 h-5"></i>
            </button>
        </div>
    </div>

    <div class="swiper related-swiper pb-12">
        <div class="swiper-wrapper">
            {% for related in product.related_products %}
            <div class="swiper-slide h-auto">
                <div class="group relative bg-white rounded-[2rem] overflow-hidden border border-neutral-200/60 h-full flex flex-col transition-all duration-700 hover:shadow-2xl hover:shadow-navy-dark/5 hover:-translate-y-3 hover:border-gold/30">
                    {% if related.on_sale %}
                        <div class="absolute top-4 right-4 z-10">
                            <span class="bg-red-600 text-white text-[10px] font-black px-3 py-1.5 rounded-full shadow-lg shadow-red-600/20">
                                خصم {{ related.discount_percentage }}%
                            </span>
                        </div>
                    {% endif %}
                    <button salla-wishlist-add="{{ related.id }}"
                        aria-label="{{ trans('common.elements.add_to_wishlist') }}"
                        class="absolute top-4 left-4 z-10 w-10 h-10 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-navy-dark hover:bg-red-500 hover:text-white transition-all shadow-xl opacity-0 group-hover:opacity-100 -translate-x-4 group-hover:translate-x-0">
                        <i data-lucide="heart" class="w-5 h-5"></i>
                    </button>
                    <div class="relative aspect-[4/5] overflow-hidden bg-soft-white">
                        <a href="{{ related.url }}" class="block w-full h-full" aria-label="{{ related.name }}">
                            <img src="{{ related.image.url }}" alt="{{ related.name }}"
                                class="w-full h-full object-cover transition-all duration-1000 group-hover:scale-110"
                                loading="lazy">
                        </a>
                    </div>
                    <div class="p-5 flex flex-col flex-grow">
                        {% if related.rating is defined and related.rating %}
                            <div class="flex items-center gap-1 mb-2">
                                <i data-lucide="star" class="w-3 h-3 text-gold fill-current"></i>
                                <span class="text-xs text-gray-400 font-bold">({{ related.rating }})</span>
                            </div>
                        {% endif %}
                        <p class="text-[10px] uppercase tracking-widest text-gold font-bold mb-1">
                            {{ related.category.name|default('') }}
                        </p>
                        <h3 class="font-bold text-navy-dark group-hover:text-gold transition-colors line-clamp-2 mb-4 flex-grow text-sm">
                            <a href="{{ related.url }}">{{ related.name }}</a>
                        </h3>
                        <div class="flex items-center justify-between mt-auto">
                            <div>
                                <span class="text-navy-dark font-black text-lg">{{ related.price|money }}</span>
                                {% if related.on_sale %}
                                    <span class="block text-gray-300 line-through text-xs">{{ related.regular_price|money }}</span>
                                {% endif %}
                            </div>
                            <button salla-cart-add="{{ related.id }}"
                                aria-label="{{ trans('common.elements.add_to_cart') }}"
                                class="w-11 h-11 bg-gray-50 text-navy-dark rounded-2xl flex items-center justify-center hover:bg-gold hover:text-white transition-all duration-500 shadow-sm group/btn">
                                <i data-lucide="shopping-bag" class="w-5 h-5 transition-transform group-hover/btn:scale-110"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        <div class="swiper-pagination related-pagination !-bottom-2"></div>
    </div>
</section>
{% endif %}
