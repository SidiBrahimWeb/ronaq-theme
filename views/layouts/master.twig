<!DOCTYPE html>
<html lang="{{ store.language.code }}" dir="{{ store.language.direction }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# Salla Required Head Tag - يجب أن يكون دائماً في الـ Head #}
    {% head %}

    {# Google Fonts: Cairo #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    {# Swiper CSS #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    {# Theme CSS - المُجمَّع بواسطة Vite #}
    <link rel="stylesheet" href="{{ asset('dist/style.css') }}">

    {# Lucide Icons #}
    <script src="https://unpkg.com/lucide@latest" defer></script>

    {# Swiper JS #}
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
</head>

<body class="font-cairo bg-soft-white text-navy-dark antialiased">

    {# شريط الإعلانات العلوي #}
    {% include 'components.header.announcement-bar' %}

    {# الهيدر الرئيسي #}
    {% include 'components.header' %}

    {# قائمة الجوال الجانبية #}
    {% include 'components.header.mobile-menu' %}

    {# محتوى الصفحة #}
    <main id="main-content" role="main">
        {% block content %}{% endblock %}
    </main>

    {# الفوتر #}
    {% include 'components.footer' %}

    {# زر العودة للأعلى #}
    <button id="back-to-top" aria-label="{{ trans('common.elements.back_to_top') }}"
        class="fixed bottom-8 left-8 w-12 h-12 bg-gold text-white rounded-full shadow-xl flex items-center justify-center z-50 opacity-0 translate-y-4 transition-all duration-500 hover:bg-navy-dark">
        <i data-lucide="arrow-up" class="w-5 h-5"></i>
    </button>

    {# Salla Required Footer Tag - السكريبتات والـ Modals الخاصة بسلة #}
    {% footer %}

    {# Theme Main JS - المُجمَّع بواسطة Vite #}
    <script src="{{ asset('dist/main.js') }}" defer></script>
</body>
</html>
