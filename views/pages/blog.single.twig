{% extends "layouts.master" %}

{% block content %}
<div class="py-10 lg:py-16">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">

            {# Breadcrumbs #}
            {% if breadcrumbs is defined and breadcrumbs|length %}
            <nav aria-label="breadcrumb" class="flex items-center gap-2 text-xs font-bold text-gray-400 mb-8 overflow-x-auto whitespace-nowrap">
                {% for breadcrumb in breadcrumbs %}
                    <a href="{{ breadcrumb.url }}" class="hover:text-gold transition-colors {% if loop.last %}text-navy-dark pointer-events-none{% endif %}">
                        {{ breadcrumb.title }}
                    </a>
                    {% if not loop.last %}
                        <i data-lucide="chevron-left" class="w-3 h-3 shrink-0"></i>
                    {% endif %}
                {% endfor %}
            </nav>
            {% endif %}

            {# رأس المقال #}
            <header class="mb-10">
                {% if blog.category is defined and blog.category %}
                    <span class="inline-block bg-gold/10 text-gold text-xs font-bold px-4 py-1.5 rounded-full mb-4">
                        {{ blog.category.name }}
                    </span>
                {% endif %}
                <h1 class="text-3xl lg:text-5xl font-black text-navy-dark leading-tight mb-6">{{ blog.title }}</h1>
                <div class="flex items-center gap-6 text-sm text-gray-400 pb-6 border-b border-gray-100">
                    {% if blog.author is defined %}
                    <span class="flex items-center gap-2">
                        <i data-lucide="user" class="w-4 h-4 text-gold"></i>
                        {{ blog.author.name }}
                    </span>
                    {% endif %}
                    <span class="flex items-center gap-2">
                        <i data-lucide="calendar" class="w-4 h-4 text-gold"></i>
                        {{ blog.created_at|date("Y/m/d") }}
                    </span>
                    {% if blog.reading_time is defined %}
                    <span class="flex items-center gap-2">
                        <i data-lucide="clock" class="w-4 h-4 text-gold"></i>
                        {{ blog.reading_time }} دقيقة قراءة
                    </span>
                    {% endif %}
                </div>
            </header>

            {# صورة المقال الرئيسية #}
            {% if blog.image is defined %}
            <div class="rounded-3xl overflow-hidden mb-10 shadow-xl">
                <img src="{{ blog.image.url|default(blog.image) }}" alt="{{ blog.title }}"
                    class="w-full aspect-[16/7] object-cover">
            </div>
            {% endif %}

            {# محتوى المقال #}
            <div class="prose prose-lg max-w-none text-neutral-600 leading-loose mb-12">
                {{ blog.content|raw }}
            </div>

            {# الوسوم والمشاركة #}
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6 py-8 border-t border-gray-100">
                {% if blog.tags is defined and blog.tags|length %}
                <div class="flex items-center flex-wrap gap-2">
                    <span class="text-sm font-bold text-gray-400">{{ trans('blog.tags') }}:</span>
                    {% for tag in blog.tags %}
                        <span class="px-3 py-1 bg-gray-100 text-gray-500 text-xs rounded-full font-bold">{{ tag }}</span>
                    {% endfor %}
                </div>
                {% endif %}

                <div class="flex items-center gap-3">
                    <span class="text-sm font-bold text-gray-400">{{ trans('blog.share') }}:</span>
                    <a href="https://twitter.com/intent/tweet?url={{ blog.url }}" target="_blank" rel="noopener noreferrer"
                        class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-gold hover:text-white transition-all">
                        <i data-lucide="twitter" class="w-4 h-4"></i>
                    </a>
                    <a href="https://wa.me/?text={{ blog.url }}" target="_blank" rel="noopener noreferrer"
                        class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-green-500 hover:text-white transition-all">
                        <i data-lucide="message-circle" class="w-4 h-4"></i>
                    </a>
                    <button id="copy-link-btn" data-url="{{ blog.url }}"
                        class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center hover:bg-navy-dark hover:text-white transition-all">
                        <i data-lucide="link" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

            {# العودة للمدونة #}
            <div class="mt-8">
                <a href="{{ link('blog') }}" class="inline-flex items-center gap-2 text-gold font-bold hover:gap-4 transition-all">
                    <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    {{ trans('blog.back_to_blog') }}
                </a>
            </div>

        </div>
    </div>
</div>
{% endblock %}
