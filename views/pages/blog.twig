{% extends "layouts.master" %}

{% block content %}
<div class="py-10 lg:py-16">
    <div class="container mx-auto px-4">

        <div class="text-center mb-14">
            <span class="inline-block text-gold font-bold text-sm tracking-widest mb-2">{{ trans('blog.title') }}</span>
            <h1 class="text-4xl font-black text-navy-dark mb-3">{{ trans('blog.subtitle') }}</h1>
            <div class="w-16 h-1 bg-gold rounded-full mx-auto"></div>
        </div>

        {% if blogs is defined and blogs|length %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {% for post in blogs %}
                <article class="group bg-white rounded-3xl overflow-hidden border border-neutral-100 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500">
                    {# صورة المقال #}
                    <div class="relative aspect-[16/10] overflow-hidden">
                        <a href="{{ post.url }}">
                            <img src="{{ post.image.url|default(post.image) }}" alt="{{ post.title }}"
                                class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110">
                        </a>
                        {% if post.category is defined and post.category %}
                            <span class="absolute top-4 right-4 bg-gold text-white text-xs font-bold px-3 py-1 rounded-full">
                                {{ post.category.name }}
                            </span>
                        {% endif %}
                    </div>

                    {# محتوى المقال #}
                    <div class="p-6">
                        <div class="flex items-center gap-4 text-xs text-gray-400 mb-3">
                            <span class="flex items-center gap-1">
                                <i data-lucide="calendar" class="w-3 h-3"></i>
                                {{ post.created_at|date("Y/m/d") }}
                            </span>
                            {% if post.author is defined %}
                            <span class="flex items-center gap-1">
                                <i data-lucide="user" class="w-3 h-3"></i>
                                {{ post.author.name }}
                            </span>
                            {% endif %}
                        </div>
                        <h2 class="text-xl font-black text-navy-dark group-hover:text-gold transition-colors mb-3 line-clamp-2">
                            <a href="{{ post.url }}">{{ post.title }}</a>
                        </h2>
                        <p class="text-gray-500 text-sm leading-relaxed mb-5 line-clamp-3">
                            {{ post.excerpt|default(post.content|striptags|slice(0,150) ~ '...') }}
                        </p>
                        <a href="{{ post.url }}" class="inline-flex items-center gap-2 font-bold text-gold text-sm hover:gap-4 transition-all">
                            {{ trans('blog.read_more') }}
                            <i data-lucide="arrow-left" class="w-4 h-4"></i>
                        </a>
                    </div>
                </article>
                {% endfor %}
            </div>

            {# الترقيم #}
            {% if blogs.pages is defined and blogs.pages > 1 %}
            <div class="flex items-center justify-center gap-3 mt-12">
                {% if blogs.prev_page %}
                    <a href="{{ blogs.prev_page }}" class="w-12 h-12 border border-gray-200 rounded-full flex items-center justify-center hover:border-gold hover:text-gold transition-all">
                        <i data-lucide="chevron-right" class="w-5 h-5"></i>
                    </a>
                {% endif %}
                {% for page in 1..blogs.pages %}
                    <a href="?page={{ page }}" class="w-12 h-12 border rounded-full flex items-center justify-center font-bold text-sm transition-all {% if page == blogs.current_page %}bg-gold text-white border-gold{% else %}border-gray-200 hover:border-gold hover:text-gold{% endif %}">
                        {{ page }}
                    </a>
                {% endfor %}
                {% if blogs.next_page %}
                    <a href="{{ blogs.next_page }}" class="w-12 h-12 border border-gray-200 rounded-full flex items-center justify-center hover:border-gold hover:text-gold transition-all">
                        <i data-lucide="chevron-left" class="w-5 h-5"></i>
                    </a>
                {% endif %}
            </div>
            {% endif %}

        {% else %}
            <div class="text-center py-20">
                <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i data-lucide="file-text" class="w-10 h-10 text-gray-300"></i>
                </div>
                <p class="text-gray-400 text-lg">{{ trans('blog.no_posts') }}</p>
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
