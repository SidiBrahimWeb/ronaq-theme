{% extends "layouts.master" %}

{% block content %}
<div class="py-10 lg:py-16">
    <div class="container mx-auto px-4">

        <div class="text-center mb-14">
            <span class="inline-block text-gold font-bold text-sm tracking-widest mb-2">{{ trans('brands.subtitle') }}</span>
            <h1 class="text-4xl font-black text-navy-dark mb-3">{{ trans('brands.title') }}</h1>
            <div class="w-16 h-1 bg-gold rounded-full mx-auto"></div>
        </div>

        {% if brands is defined and brands|length %}
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
                {% for brand in brands %}
                <a href="{{ brand.url }}" class="group bg-white rounded-3xl p-6 border border-neutral-100 text-center transition-all duration-500 hover:shadow-xl hover:-translate-y-2 hover:border-gold/30">
                    <div class="w-24 h-24 mx-auto mb-4 flex items-center justify-center rounded-full bg-soft-white overflow-hidden transition-all group-hover:ring-2 ring-gold/30">
                        {% if brand.image is defined and brand.image %}
                            <img src="{{ brand.image.url|default(brand.image) }}" alt="{{ brand.name }}"
                                class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all duration-500">
                        {% else %}
                            <span class="text-3xl font-black text-gray-300 group-hover:text-gold transition-colors">{{ brand.name|slice(0,1) }}</span>
                        {% endif %}
                    </div>
                    <h3 class="font-bold text-navy-dark group-hover:text-gold transition-colors">{{ brand.name }}</h3>
                    {% if brand.products_count is defined %}
                        <p class="text-xs text-gray-400 mt-1">{{ brand.products_count }} {{ trans('brands.products_count') }}</p>
                    {% endif %}
                </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-20">
                <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i data-lucide="award" class="w-10 h-10 text-gray-300"></i>
                </div>
                <p class="text-gray-400 text-lg">{{ trans('brands.no_brands') }}</p>
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
