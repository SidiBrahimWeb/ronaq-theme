{% extends "layouts.master" %}

{% block content %}
<div class="py-8 lg:py-12">
    <div class="container mx-auto px-4">

        {# مسار التنقل #}
        {% if breadcrumbs is defined and breadcrumbs|length %}
        <nav aria-label="breadcrumb" class="flex items-center gap-2 text-xs font-bold text-gray-400 mb-6 overflow-x-auto whitespace-nowrap">
            {% for breadcrumb in breadcrumbs %}
                <a href="{{ breadcrumb.url }}" class="hover:text-gold transition-colors {% if loop.last %}text-navy-dark pointer-events-none{% endif %}">
                    {{ breadcrumb.title }}
                </a>
                {% if not loop.last %}
                    <i data-lucide="chevron-left" class="w-3 h-3 shrink-0"></i>
                {% endif %}
            {% endfor %}
        </nav>
        {% endif %}

        {# رأس الصفحة #}
        <div class="mb-10">
            <h1 class="text-3xl lg:text-4xl font-black text-navy-dark mb-2">{{ category.name }}</h1>
            {% if category.description %}
                <p class="text-gray-500 max-w-2xl">{{ category.description }}</p>
            {% endif %}
        </div>

        {# التصنيفات الفرعية #}
        {% if category.sub_categories is defined and category.sub_categories|length %}
        <div class="flex gap-3 flex-wrap mb-10">
            <a href="{{ category.url }}" class="px-5 py-2 rounded-full border-2 border-gold bg-gold text-white text-sm font-bold">
                {{ trans('common.elements.all_categories') }}
            </a>
            {% for sub in category.sub_categories %}
                <a href="{{ sub.url }}" class="px-5 py-2 rounded-full border-2 border-gray-200 text-gray-500 text-sm font-bold hover:border-gold hover:text-gold transition-all">
                    {{ sub.name }}
                </a>
            {% endfor %}
        </div>
        {% endif %}

        {# شريط الفلترة والترتيب #}
        <div class="flex items-center justify-between mb-8 py-4 border-y border-gray-100">
            <p class="text-sm text-gray-500 font-bold">
                {{ products.total|default(0) }} منتج
            </p>
            <div class="flex items-center gap-4">
                <label class="text-sm font-bold text-gray-500">{{ trans('common.elements.sort_by') }}:</label>
                <select salla-sort-products class="bg-white border border-gray-200 rounded-xl px-4 py-2 text-sm font-bold text-navy-dark focus:outline-none focus:border-gold">
                    <option value="newest">الأحدث</option>
                    <option value="price_asc">الأقل سعراً</option>
                    <option value="price_desc">الأعلى سعراً</option>
                    <option value="best_selling">الأكثر مبيعاً</option>
                    <option value="rating">الأعلى تقييماً</option>
                </select>
            </div>
        </div>

        {# شبكة المنتجات #}
        {% if products is defined and products|length %}
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
                {% for product in products %}
                    <div class="group relative bg-white rounded-3xl overflow-hidden border border-neutral-200/60 flex flex-col transition-all duration-500 hover:shadow-2xl hover:shadow-navy-dark/5 hover:-translate-y-2 hover:border-gold/30">
                        <div class="relative aspect-[4/5] overflow-hidden bg-soft-white">
                            <a href="{{ product.url }}" class="block w-full h-full">
                                <img src="{{ product.image.url }}" alt="{{ product.name }}"
                                    class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110">
                            </a>
                            <div class="absolute top-4 right-4 flex flex-col gap-2 z-10">
                                {% if product.on_sale %}
                                    <span class="bg-red-600 text-white text-[10px] font-black px-3 py-1 rounded-full">
                                        خصم {{ product.discount_percentage }}%
                                    </span>
                                {% endif %}
                                {% if product.is_new %}
                                    <span class="bg-navy-dark text-white text-[10px] font-black px-3 py-1 rounded-full">
                                        {{ trans('common.elements.new') }}
                                    </span>
                                {% endif %}
                            </div>
                            <button salla-wishlist-add="{{ product.id }}"
                                class="absolute top-4 left-4 z-10 w-10 h-10 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-navy-dark hover:bg-red-500 hover:text-white transition-all shadow-lg opacity-0 group-hover:opacity-100">
                                <i data-lucide="heart" class="w-5 h-5"></i>
                            </button>
                        </div>

                        <div class="p-4 flex flex-col flex-grow">
                            <p class="text-[10px] uppercase tracking-widest text-gold font-bold mb-1">
                                {{ product.category.name|default('') }}
                            </p>
                            <h3 class="font-bold text-navy-dark group-hover:text-gold transition-colors line-clamp-2 mb-3 flex-grow">
                                <a href="{{ product.url }}">{{ product.name }}</a>
                            </h3>
                            <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-50">
                                <div>
                                    <span class="text-navy-dark font-black text-lg">{{ product.price|money }}</span>
                                    {% if product.on_sale %}
                                        <span class="block text-gray-300 line-through text-xs">{{ product.regular_price|money }}</span>
                                    {% endif %}
                                </div>
                                <button salla-cart-add="{{ product.id }}"
                                    class="w-11 h-11 bg-navy-dark text-white rounded-2xl flex items-center justify-center hover:bg-gold transition-all duration-500 shrink-0">
                                    <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# الترقيم - Pagination #}
            {% if products.pages is defined and products.pages > 1 %}
            <div class="flex items-center justify-center gap-3 mt-12">
                {% if products.prev_page %}
                    <a href="{{ products.prev_page }}" class="w-12 h-12 border border-gray-200 rounded-full flex items-center justify-center hover:border-gold hover:text-gold transition-all">
                        <i data-lucide="chevron-right" class="w-5 h-5"></i>
                    </a>
                {% endif %}
                {% for page in 1..products.pages %}
                    <a href="?page={{ page }}" class="w-12 h-12 border rounded-full flex items-center justify-center font-bold text-sm transition-all {% if page == products.current_page %}bg-gold text-white border-gold{% else %}border-gray-200 hover:border-gold hover:text-gold{% endif %}">
                        {{ page }}
                    </a>
                {% endfor %}
                {% if products.next_page %}
                    <a href="{{ products.next_page }}" class="w-12 h-12 border border-gray-200 rounded-full flex items-center justify-center hover:border-gold hover:text-gold transition-all">
                        <i data-lucide="chevron-left" class="w-5 h-5"></i>
                    </a>
                {% endif %}
            </div>
            {% endif %}

        {% else %}
            <div class="text-center py-24">
                <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i data-lucide="package-x" class="w-10 h-10 text-gray-300"></i>
                </div>
                <h3 class="text-xl font-bold text-navy-dark mb-2">{{ trans('common.elements.no_results') }}</h3>
                <p class="text-gray-400 mb-6">لا توجد منتجات في هذا التصنيف حالياً</p>
                <a href="{{ link('/') }}" class="inline-flex items-center gap-2 bg-navy-dark text-white px-8 py-4 rounded-xl font-bold hover:bg-gold transition-all">
                    {{ trans('common.elements.home') }}
                </a>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
