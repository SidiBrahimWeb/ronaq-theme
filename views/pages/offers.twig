{% extends "layouts.master" %}

{% block content %}
<div class="py-10 lg:py-16">
    <div class="container mx-auto px-4">

        {# رأس الصفحة #}
        <div class="text-center mb-14">
            <span class="inline-block text-gold font-bold text-sm tracking-widest mb-2">{{ trans('offers.subtitle') }}</span>
            <h1 class="text-4xl font-black text-navy-dark mb-3">{{ trans('offers.title') }}</h1>
            <div class="w-16 h-1 bg-gold rounded-full mx-auto"></div>
        </div>

        {% if products is defined and products|length %}
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
                {% for product in products %}
                <div class="group relative bg-white rounded-3xl overflow-hidden border border-neutral-200/60 flex flex-col transition-all duration-500 hover:shadow-xl hover:-translate-y-2 hover:border-gold/30">
                    <div class="relative aspect-[4/5] overflow-hidden bg-soft-white">
                        <a href="{{ product.url }}" class="block w-full h-full">
                            <img src="{{ product.image.url }}" alt="{{ product.name }}"
                                class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110">
                        </a>
                        {# شارة الخصم #}
                        {% if product.on_sale %}
                            <span class="absolute top-4 right-4 bg-red-600 text-white text-[10px] font-black px-3 py-1.5 rounded-full shadow-lg shadow-red-600/30">
                                خصم {{ product.discount_percentage }}%
                            </span>
                        {% endif %}
                        <button salla-wishlist-add="{{ product.id }}"
                            class="absolute top-4 left-4 w-10 h-10 bg-white/90 backdrop-blur-md rounded-full flex items-center justify-center text-navy-dark hover:bg-red-500 hover:text-white transition-all shadow-lg opacity-0 group-hover:opacity-100">
                            <i data-lucide="heart" class="w-5 h-5"></i>
                        </button>
                    </div>
                    <div class="p-4 flex flex-col flex-grow">
                        <p class="text-[10px] uppercase tracking-widest text-gold font-bold mb-1">{{ product.category.name|default('') }}</p>
                        <h3 class="font-bold text-navy-dark group-hover:text-gold transition-colors line-clamp-2 mb-3 flex-grow">
                            <a href="{{ product.url }}">{{ product.name }}</a>
                        </h3>
                        <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-50">
                            <div>
                                <span class="text-navy-dark font-black text-lg">{{ product.price|money }}</span>
                                {% if product.on_sale %}
                                    <span class="block text-gray-300 line-through text-xs">{{ product.regular_price|money }}</span>
                                {% endif %}
                            </div>
                            <button salla-cart-add="{{ product.id }}"
                                class="w-11 h-11 bg-navy-dark text-white rounded-2xl flex items-center justify-center hover:bg-gold transition-all">
                                <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                            </button>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-20">
                <div class="w-24 h-24 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i data-lucide="tag" class="w-10 h-10 text-gray-300"></i>
                </div>
                <h2 class="text-xl font-bold text-navy-dark mb-2">{{ trans('offers.no_offers') }}</h2>
                <a href="{{ link('/') }}" class="inline-flex items-center gap-2 bg-gold text-white px-8 py-4 rounded-xl font-bold mt-4 hover:bg-navy-dark transition-all">
                    {{ trans('common.elements.home') }}
                </a>
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}
